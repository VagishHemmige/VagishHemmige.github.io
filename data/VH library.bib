@article{madanTrendsUseEarly2025,
  title = {Trends in {{Use}} and {{Early Outcomes}} of {{Ex Vivo Machine Perfusion}} in {{Heart Transplantation From Donation After Brain Death Donors}}.},
  author = {Madan, Shivank and D'Angelo, Lorenzo and Teitelbaum, Jill and Ferrell, Brandon and Hemmige, Vagish and Forest, Stephen J. and Saeed, Omar and Goldstein, Daniel J. and Jorde, Ulrich P. and Patel, Snehal R.},
  year = 2025,
  month = dec,
  journal = {Journal of cardiac failure},
  pages = {S1071-9164(25)00511-1},
  address = {United States},
  issn = {1532-8414 1071-9164},
  doi = {10.1016/j.cardfail.2025.09.039},
  abstract = {INTRODUCTION: Hearts from donation after brain death (DBD) donors are increasingly older and transported over greater distances, prolonging ischemic  times and increasing ischemic injury risks with conventional static cold storage  (SCS). Ex vivo machine-perfusion (EVMP) of DBD donor hearts could mitigate these  risks, potentially improving outcomes, especially in older donors. However,  broader use rates and outcomes of EVMP remain uncertain. METHODS: In total,  12,363 adult DBD-HTs (11,802 SCS, 561 EVMP) that met study criteria (January  2020-June 2024) were identified in United Network for Organ Sharing. EVMP use and  recipient survival at 6 months and 1 year were analyzed, stratified by ischemic  time ({$<$}4, 4-6, {$\geq$}6 hours), including subgroup analysis for older donors ({$>$}40  years). Cox hazards regression (Cox-HR), Kaplan-Meier survival, and  marginal-effects probabilities were used. RESULTS: EVMP use in DBD-HTs increased  from 1.39\% (January-June 2020) to 10.65\% (January-June 2024), with substantial  regional variability and few high-volume centers driving most of this use.  Compared with DBD-HTs with SCS, DBD-HTs with EVMP had similar mortality risk at 6  months and 1 year (Cox-HR, 1.12; 0.86-1.45; P\,=\,.414), despite EVMP hearts being  from older donors, transported longer distances, and having longer ischemic  times. On stratifying by ischemic time and older donors, although DBD-HTs with  SCS had higher 1-year mortality risk (Cox-HR=3.69; 1.81-7.51; P {$<$}.001,  ischemic-time {$\geq$}6 hours) compared with the reference cohort, the increase in  mortality was substantially attenuated in DBD-HTs where EVMP was used (Cox-HR,  1.77; 0.87-3.61; P\,=\,.115, ischemic time {$\geq$}6 hours). CONCLUSIONS: Adoption of EVMP  for donor heart transport in DBD-HTs has steadily increased in the United States,  showing comparable survival outcomes to SCS despite older donors and longer  ischemic times. Additional studies comparing EVMP with other emerging heart  transport technologies are needed.},
  copyright = {Copyright \copyright{} 2025 Elsevier Inc. All rights reserved.},
  langid = {english},
  pmid = {41339160},
  keywords = {DBD,donation after brain death,EVMP,ex vivo machine perfusion,Heart transplantation,transplant outcomes}
}

@article{naurozTrendsTimePractice2025,
  title = {Trends over {{Time}} in {{Practice}} and {{Outcomes}} of {{Lung Transplantation}} in {{Recipients}} with {{Human Immunodeficiency Virus}}},
  author = {Nauroz, Zeba and Ruck, Jessica M. and Shah, Pali and Bush, Errol and Werbel, William and Raju, Sarath and Hemmige, Vagish and Haidar, Ghady and Massie, Allan B. and Segev, Dorry L. and Durand, Christine M. and Bowring, Mary G.},
  year = 2025,
  month = aug,
  journal = {Transplant Infectious Disease: An Official Journal of the Transplantation Society},
  pages = {e70090},
  issn = {1399-3062},
  doi = {10.1111/tid.70090},
  abstract = {BACKGROUND: People with human immunodeficiency virus (HIV) are at an increased risk for end-stage lung disease, for which lung transplantation (LT) may be necessary. METHODS: We aimed to characterize the national practice patterns of LT in recipients with HIV (HIV R+) and post-LT outcomes, including rejection in the US over time. Using the Scientific Registry of Transplant Recipients data (from January 1, 2004, to December 1, 2024, for practice patterns and from January 1, 2016, to December 1, 2024, for outcomes), we compared 96 adult HIV R+ to 42 341 LT recipients without HIV (HIV R-). We examined the association between HIV and outcomes using Gini coefficients, Cox regression, and modified Poisson regression before and after 2020. RESULTS: HIV R+ LTs increased from 0.1\% in 2004 to 0.4\% of LTs in 2024 (p = 0.07). Pre-2020, 18 centers performed 80\% of HIV R+ LTs (Gini = 0.78); post-2020, 14 centers performed 80\% of HIV R+ LTs (Gini = 0.76), indicating no expansion of the practice across centers. HIV R+ did not have an increased risk of mortality (adjusted hazard ratio pre-2020: 0.91 [95\% confidence interval 0.41-1.62], p = 0.7 and post-2020: 1.05 [0.49-3.25], p = 0.8), or increased risk of 1-year rejection rate (adjusted relative risk pre-2020: 0.60 [0.20-1.77], p = 0.3, and post-2020: 0.77 [0.26-2.2], p = 0.6). CONCLUSIONS: Increasing numbers of HIV R+ LTs and comparable outcomes to those without HIV are encouraging, yet few centers perform these transplants.},
  langid = {english},
  pmid = {40778480},
  keywords = {HIV,lung transplantation,patient survival}
}

@article{patelActivatingRacialEthnic2017,
  title = {Activating {{Racial}} and {{Ethnic Minorities}} to {{Engage}} in {{Preventive Health}}: {{Patient Preferences}} for {{Health Reminders}}},
  shorttitle = {Activating {{Racial}} and {{Ethnic Minorities}} to {{Engage}} in {{Preventive Health}}},
  author = {Patel, Sajani and Hemmige, Vagish and Street, Richard L. and Viswanath, Kasisomayajula and Arya, Monisha},
  year = 2017,
  journal = {Journal of Participatory Medicine},
  volume = {9},
  pages = {e8},
  issn = {2152-7202},
  abstract = {OBJECTIVES: The objective of this study was to determine racial and ethnic minority patient receptiveness to health reminders, and preferences for media channels and messengers for preventive health reminders. METHODS: A pen and paper survey was administered to patients in the waiting room of a publicly funded clinic serving predominately racial and ethnic minorities. RESULTS: Three-fourths of participants said they would like to receive health reminders. The top three preferred methods of receiving health reminders were via text message, phone call, and letter by mail. About half of participants wanted their doctor or nurse to send them the health reminder. CONCLUSIONS: Health reminders could be a tool to successfully encourage racial and ethnic minority patients to participate in their own health. If physicians or nurses use a cell phone text message, a phone call, or a letter to send these health reminders they may be particularly effective at improving patient health outcomes.},
  langid = {english},
  pmcid = {PMC5736376},
  pmid = {29270330},
  keywords = {cell phone,Health reminders,patient activation,patient preferences,preventive health}
}

